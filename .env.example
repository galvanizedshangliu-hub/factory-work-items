# 示例环境变量文件（不要将真实密钥提交到仓库）
# 复制为 .env 并在启动前填写实际值，或者把变量导出到系统环境中

# DeepSeek / OpenAI 兼容 API Key
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 钉钉应用凭证
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=

# 可选：钉钉群推送 webhook（仅用于单向推送）
DINGTALK_WEBHOOK=

# 其他可选设置
DATA_DIR=data
LOG_FILE=logs/agent.log
